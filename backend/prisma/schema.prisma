generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Product {
  id        Int     @id @default(autoincrement())
  name      String
  price     Float
  stock     Int     @default(0)
  createdAt DateTime @default(now())
}

model Customer {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}

model Order {
  id        Int      @id @default(autoincrement())
  total     Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int
  price     Float
}

model Coupon {
  id        Int     @id @default(autoincrement())
  code      String  @unique
  percent   Int
  active    Boolean @default(true)
}

model Category {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  products Product[]
}
